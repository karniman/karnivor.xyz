---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts } from "../../lib/blog";

const posts = await getAllPosts();
const canonical = new URL("/blog/", Astro.site).toString();
const title = "Блог";
const description =
  "Статьи karnivor.xyz о карнивор диете, мясном питании, переходе на животную пищу, частых ошибках, жире, белке и практическом опыте.";
const heroImage = "/images/karnivor-strength.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Блог karnivor.xyz",
  url: canonical,
  inLanguage: "ru",
  description,
  blogPost: posts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    url: new URL(`/blog/${post.slug}/`, Astro.site).toString(),
    datePublished: post.publishedAt,
    dateModified: post.updatedAt,
    inLanguage: "ru",
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} image={heroImage} jsonLd={jsonLd}>
  <main>
    <section class="page-hero page-hero--with-illustration">
      <div class="page-hero__content">
        <p class="eyebrow">Блог</p>
        <h1>Статьи о карнивор диете</h1>
        <p class="hero__lead">
          Короткие материалы для поисковых запросов и внутренней перелинковки: продукты, переход,
          частые ошибки, жир, белок и практические вопросы.
        </p>
      </div>
      <div class="page-hero__visual photo-card photo-card--blog">
        <img
          class="page-hero__illustration"
          src={heroImage}
          alt="Атлет поднимает гантели"
          width="1448"
          height="1086"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <section class="content-band">
      <div class="blog-list">
        {
          posts.map((post) => (
            <article class="blog-card">
              <a class="blog-card__link" href={`/blog/${post.slug}/`}>
                <div class="blog-card__meta">
                  <time datetime={post.publishedAt}>
                    {new Intl.DateTimeFormat("ru-RU", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                    }).format(new Date(`${post.publishedAt}T00:00:00`))}
                  </time>
                  <span>{post.readingMinutes} мин чтения</span>
                </div>
                <h2>{post.title}</h2>
                <p>{post.description}</p>
                <div class="tag-row" aria-label="Темы статьи">
                  {post.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
