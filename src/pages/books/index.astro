---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookCover from "../../components/BookCover.astro";
import { getAllBooks } from "../../lib/books";

const books = await getAllBooks();
const firstBook = books[0];
const canonical = new URL("/books/", Astro.site).toString();
const title = "Карнивор книги";
const description =
  "Бесплатные русскоязычные книги karnivor.xyz о карнивор диете, мясо-жировом питании, Стефанссоне, Оусли Стэнли и практическом отказе от промышленной еды.";
const heroImage = "/images/karnivor-books.png";
const promoImage = "/images/karnivor-squat.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Карнивор книги",
  url: canonical,
  inLanguage: "ru",
  description,
  hasPart: books.map((book) => ({
    "@type": "Book",
    name: book.title,
    url: new URL(`/books/${book.slug}/`, Astro.site).toString(),
    isAccessibleForFree: true,
    inLanguage: book.language,
  })),
};
---

<BaseLayout title={title} description={description} canonical={canonical} image={heroImage} jsonLd={jsonLd}>
  <main>
    <section class="page-hero page-hero--with-illustration">
      <div class="page-hero__content">
        <p class="eyebrow">Книги</p>
        <h1>Карнивор книги</h1>
        <p class="hero__lead">
          Бесплатные книги с отдельными главами: удобно читать, искать и возвращаться
          к нужным темам без ленты и лишнего шума.
        </p>
      </div>
      <div class="page-hero__visual photo-card photo-card--books">
        <img
          class="page-hero__illustration"
          src={heroImage}
          alt="Книги о питании животными продуктами"
          width="1448"
          height="1086"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <section class="content-band" id="books-list">
      <div class="book-grid">
        {
          books.map((book) => (
            <article class="book-card">
              <a class="book-card__cover" href={`/books/${book.slug}/`}>
                <BookCover
                  title={book.title}
                  subtitle={book.subtitle}
                  image={book.coverImage}
                  width={book.coverWidth}
                  height={book.coverHeight}
                />
              </a>
              <div class="book-card__body">
                <h2>{book.title}</h2>
                <p>{book.description}</p>
                <dl class="compact-meta">
                  <div>
                    <dt>Разделов</dt>
                    <dd>{book.chapters.length}</dd>
                  </div>
                  <div>
                    <dt>Чтение</dt>
                    <dd>{book.readingMinutes} мин</dd>
                  </div>
                  <div>
                    <dt>Объем</dt>
                    <dd>{book.wordCount.toLocaleString("ru-RU")} слов</dd>
                  </div>
                </dl>
                <div class="actions">
                  <a class="button button--primary" href={`/books/${book.slug}/${book.chapters[0].slug}/`}>Читать онлайн</a>
                  <a class="button button--secondary" href={`/books/${book.slug}/`}>Подробнее</a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-band content-band--alt">
      <div class="books-promo-layout">
        <div class="books-promo-layout__copy">
          <div class="section-heading">
            <p class="eyebrow">Бесплатно и без барьеров</p>
            <h2>Выберите книгу и начните читать сразу</h2>
            <p>
              Все книги открыты целиком: без регистрации, рекламы и подписки. Можно читать онлайн по
              главам, возвращаться к нужным местам из закладок и делиться ссылками на конкретные
              разделы.
            </p>
          </div>
          <div class="prose-columns">
            <p>
              Онлайн-страницы удобны для быстрого чтения с телефона или ноутбука: открыл главу,
              прочитал, продолжил позже там же.
            </p>
            <p>
              Для офлайна доступны PDF, EPUB и FB3. Скачайте книгу на электронную читалку, планшет
              или телефон и берите материалы с собой.
            </p>
          </div>
          <div class="actions">
            <a class="button button--primary" href={`/books/${firstBook.slug}/${firstBook.chapters[0].slug}/`}>
              Начать читать
            </a>
            <a class="button button--secondary" href="#books-list">Выбрать книгу</a>
          </div>
        </div>
        <div class="books-promo-layout__visual photo-card photo-card--squat">
          <img
            class="books-promo-illustration"
            src={promoImage}
            alt="Иллюстрация: атлет приседает со штангой"
            width="1448"
            height="1086"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
