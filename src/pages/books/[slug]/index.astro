---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BookCover from "../../../components/BookCover.astro";
import { getAllBooks, type Book } from "../../../lib/books";

export async function getStaticPaths() {
  const books = await getAllBooks();
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

interface Props {
  book: Book;
}

const { book } = Astro.props;
const firstChapter = book.chapters[0];
const downloadFileBases: Record<string, string> = {
  "common-drugs": "Gorbushkin_Grisha_Alkogol_kofein_i_sahar_kak_bytovye_narkotiki",
  "karnivor-dieta": "Gorbushkin_Grisha_Karnivor_Dieta",
  "owsley-stanley": "Gorbushkin_Grisha_Owsley_Stanley_i_karnivor_dieta",
  "vilhjalmur-stefansson": "Gorbushkin_Grisha_Vilhjalmur_Stefansson_i_karnivor_dieta",
};
const downloadFileBase = downloadFileBases[book.slug];
const downloadFormats = downloadFileBase
  ? [
      {
        label: "PDF",
        href: `/downloads/${book.slug}/${downloadFileBase}.a4.pdf`,
      },
      {
        label: "EPUB",
        href: `/downloads/${book.slug}/${downloadFileBase}.epub`,
      },
      {
        label: "FB3",
        href: `/downloads/${book.slug}/${downloadFileBase}.fb3`,
      },
    ]
  : [];
const canonical = new URL(`/books/${book.slug}/`, Astro.site).toString();
const title = `${book.title} - читать онлайн бесплатно`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: book.title,
  headline: title,
  description: book.description,
  author: {
    "@type": "Organization",
    name: book.author,
  },
  inLanguage: book.language,
  isAccessibleForFree: true,
  datePublished: String(book.publishedYear),
  url: canonical,
  image: new URL(book.coverImage, Astro.site).toString(),
  ...(book.litresUrl ? { sameAs: book.litresUrl } : {}),
  hasPart: book.chapters.map((chapter) => ({
    "@type": "Chapter",
    name: chapter.title,
    url: new URL(`/books/${book.slug}/${chapter.slug}/`, Astro.site).toString(),
  })),
};
---

<BaseLayout
  title={title}
  description={book.description}
  canonical={canonical}
  image={book.coverImage}
  ogType="book"
  jsonLd={jsonLd}
>
  <main>
    <section class="book-hero">
      <BookCover
        title={book.title}
        subtitle={book.subtitle}
        image={book.coverImage}
        width={book.coverWidth}
        height={book.coverHeight}
      />
      <div>
        <p class="eyebrow">Бесплатная книга</p>
        <h1>{book.title}</h1>
        <p class="book-subtitle">{book.subtitle}</p>
        <p class="hero__lead">{book.description}</p>
        <div class="actions">
          <a class="button button--primary" href={`/books/${book.slug}/${firstChapter.slug}/`}>Читать онлайн</a>
          {
            downloadFormats.map((format) => (
              <a class="button button--secondary" href={format.href} download>
                Скачать {format.label}
              </a>
            ))
          }
          {
            book.litresUrl && (
              <a class="button button--secondary external-link" href={book.litresUrl} target="_blank" rel="noopener noreferrer">
                Литрес
              </a>
            )
          }
        </div>
      </div>
    </section>

    <section class="content-band">
      <dl class="meta-grid meta-grid--wide">
        <div>
          <dt>Автор</dt>
          <dd>{book.author}</dd>
        </div>
        <div>
          <dt>Язык</dt>
          <dd>Русский</dd>
        </div>
        <div>
          <dt>Разделов</dt>
          <dd>{book.chapters.length}</dd>
        </div>
        <div>
          <dt>Объем</dt>
          <dd>{book.wordCount.toLocaleString("ru-RU")} слов</dd>
        </div>
      </dl>
    </section>

    <section class="text-section">
      <div class="section-heading">
        <p class="eyebrow">Аннотация</p>
        <h2>О книге</h2>
        <p>{book.description}</p>
      </div>
      <div class="book-annotation">
        {book.litresAnnotation.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section class="toc-section">
      <div class="section-heading">
        <p class="eyebrow">Содержание</p>
        <h2>Читать по главам</h2>
      </div>
      <ol class="chapter-list">
        {
          book.chapters.map((chapter) => (
            <li>
              <a href={`/books/${book.slug}/${chapter.slug}/`}>
                <span class="chapter-list__header">
                  <span>{chapter.title}</span>
                  <small>{chapter.readingMinutes} мин</small>
                </span>
                {chapter.excerpt && <span class="chapter-list__excerpt">{chapter.excerpt}</span>}
              </a>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="text-section">
      <div class="section-heading">
        <p class="eyebrow">О формате</p>
        <h2>Читать удобно: онлайн или в своем формате</h2>
      </div>
      <div class="prose-columns">
        <p>
          Главы открываются как обычные страницы: без отдельного приложения, регистрации и лишних
          экранов. Можно начать с телефона, вернуться с ноутбука, отправить ссылку на нужную главу
          или оставить ее в закладках.
        </p>
        <p>
          Если хочется читать офлайн, скачайте книгу в PDF, EPUB или FB3. Форматы подойдут для
          электронной книги, планшета, телефона и компьютера, чтобы взять текст с собой.
        </p>
      </div>
      <figure class="format-illustration">
        <img
          src="/images/karnivor-format-reader.png"
          alt="Иллюстрация: девушка несет тяжелую сумку как символ книги, которую удобно взять с собой"
          width="1448"
          height="1086"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </main>
</BaseLayout>
